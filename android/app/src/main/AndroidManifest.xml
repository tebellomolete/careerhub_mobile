<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Assignment 2.3 — connectivity_plus reads Android's network state
         through ConnectivityManager / NetworkCapabilities APIs, which are
         gated by this permission. Without it the connectivity stream
         initialises silently but never emits a change event, so the
         offline banner never appears on Android. Must sit immediately
         before <application>. See README 2.3, Part 2. -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- Assignment 2.4 Stretch B — biometric auth. USE_BIOMETRIC
         (API 28+) is the current permission; USE_FINGERPRINT is
         the pre-28 name. Declaring both keeps API 23–27 devices
         (which we still support because minSdk=23) able to prompt
         with fingerprint even though the modern BiometricPrompt
         constant is unavailable. See local_auth's Android integration
         section. -->
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />
    <uses-permission android:name="android.permission.USE_FINGERPRINT" />
    <!-- Assignment 2.1 — usesCleartextTraffic="true".
         Our CareerHub API runs on http://10.0.2.2:5254 in development
         (the Android emulator's alias for the host machine's localhost).
         Android 9 (API 28) and above block cleartext HTTP by default;
         without this flag Dio would fail every request with a
         SocketException before it ever reached the API. This flag is
         DEV-ONLY: a production build would remove it and target HTTPS. -->
    <application
        android:label="careerhub_mobile"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:usesCleartextTraffic="true">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>
        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
    </application>
    <!-- Required to query activities that can process text, see:
         https://developer.android.com/training/package-visibility and
         https://developer.android.com/reference/android/content/Intent#ACTION_PROCESS_TEXT.

         In particular, this is used by the Flutter engine in io.flutter.plugin.text.ProcessTextPlugin. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
    </queries>
</manifest>
